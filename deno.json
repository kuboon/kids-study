{
  "workspace": [
    "./src",
    "./src/builder",
    "./src/client",
    "./src/ssg"
  ],
  "tasks": {
    "serve": "cd dist && deno run --allow-net --allow-read jsr:@std/http/file-server",
    "build": "deno task --cwd src/builder build",
    "test": "deno test -P",
    "check": "deno check && deno lint && deno fmt --check"
  },
  "permissions": {
    "default": {}
  },
  "test": {
    "permissions": "default"
  },
  "nodeModulesDir": "auto",
  "unstable": ["bundle"]
}
